+// Manual "Buscar actualizaciones" button.
+async function checkForUpdate(){
+  if(!('serviceWorker' in navigator)){
+    if(typeof showToast==='function') showToast('Tu navegador no soporta actualizaciones');
+    return;
+  }
+  if(typeof showToast==='function') showToast('Buscando actualización...');
+  try{
+    var reg = swRegistration || await navigator.serviceWorker.getRegistration();
+    if(!reg){ if(typeof showToast==='function') showToast('No hay versión instalada aún'); return; }
+    await reg.update();
+    setTimeout(function(){
+      if(reg.installing || reg.waiting){
+        if(typeof showToast==='function') showToast('Actualización encontrada, instalando...');
+        // controllerchange will reload automatically; this is a fallback.
+        setTimeout(function(){ if(!_reloading){ _reloading = true; window.location.reload(); } }, 2500);
+      } else {
+        if(typeof showToast==='function') showToast('✓ Ya tienes la última versión (' + APP_VERSION + ')');
+      }
+    }, 1500);
+  }catch(e){
+    if(typeof showToast==='function') showToast('Error al actualizar: ' + e.message);
+  }
+}
